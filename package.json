{
  "name": "md2gost",
  "displayName": "md2gost",
  "description": "Converts markdown to docx format, trying to comply with GOST standards",
  "icon": "imgs/icon.png",
  "version": "1.0.0",
  "publisher": "MixelTe",
  "repository": {
    "url": "https://github.com/MixelTe/md2gost",
    "type": "git"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "markdown.markdownItPlugins": true,
    "commands": [
      {
        "command": "md2gost.whats_new",
        "title": "md2gost: Show update notes"
      },
      {
        "command": "md2gost.render_pdf",
        "title": "md2gost: Render current file to pdf",
        "icon": {
          "dark": "imgs/ghost_white.svg",
          "light": "imgs/ghost.svg"
        }
      },
      {
        "command": "md2gost.render_docx",
        "title": "md2gost: Render current file to docx only",
        "icon": {
          "dark": "imgs/ghost_small_white.svg",
          "light": "imgs/ghost_small.svg"
        }
      },
      {
        "command": "md2gost.render_docx_fast",
        "title": "md2gost: Render current file to docx without postprocessing",
        "icon": {
          "dark": "imgs/ghost_smallest_white.svg",
          "light": "imgs/ghost_smallest.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceFilename =~ /\\.g\\.md$/",
          "command": "md2gost.render_docx",
          "alt": "md2gost.render_docx_fast",
          "group": "navigation"
        },
        {
          "when": "resourceFilename =~ /\\.g\\.md$/",
          "command": "md2gost.render_pdf",
          "group": "navigation"
        }
      ]
    },
    "grammars": [
      {
        "scopeName": "markdown.custom.injection",
        "path": "./assets/grammars.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "injectionSelector": "L:text.html.markdown"
      }
    ],
    "configuration": {
      "title": "md2gost",
      "properties": {
        "md2gost.tables.editor.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Отображать кнопку для открытия визуального редактора таблиц."
        },
        "md2gost.tables.borderStyle": {
          "type": "string",
          "enum": [
            "enclosed",
            "none",
            "preserve"
          ],
          "default": "preserve",
          "description": "Стиль внешних границ таблиц: \"enclosed\" (добавлять «|» по краям), \"none\" (убирать границы), \"preserve\" (не изменять)."
        },
        "md2gost.tables.alwaysAddLeftColon": {
          "type": "boolean",
          "default": false,
          "description": "Определяет, нужно ли явно добавлять двоеточие для выравнивания по левому краю (например, ':---' вместо '---')."
        },
        "md2gost.tables.compact": {
          "type": "boolean",
          "default": false,
          "description": "Ячейки не будут дополняться пробелами для визуального выравнивания столбцов."
        },
        "md2gost.ui.inlayHints": {
          "type": "boolean",
          "default": true,
          "description": "Отображать встроенные подсказки в тексте (например, «Рисунок # –»)."
        },
        "md2gost.ui.disableHighlighting": {
          "type": "boolean",
          "default": false,
          "description": "Отключить кастомную подсветку Markdown (требуется перезагрузка окна)."
        },
        "md2gost.formatter.suppressDefaultPrompt": {
          "type": "boolean",
          "default": false,
          "description": "Отключает предложение использовать md2gost в качестве форматировщика по умолчанию."
        },
        "md2gost.formatter.replaceEmDash": {
          "type": "boolean",
          "default": true,
          "description": "Заменять Em dash (—) на En dash (–)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/prismjs": "^1.26.6",
    "@types/vscode": "^1.101.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "docx": "^9.5.1",
    "image-size": "^2.0.2",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "prismjs": "^1.30.0"
  }
}
