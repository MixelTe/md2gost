{
	"scopeName": "markdown.custom.injection",
	"injectionSelector": "L:text.html.markdown",
	"patterns": [
		{
			"name": "constant.numeric.integer.markdown",
			"match": "\\[[a-zA-Z–∞-—П–Р-–ѓ—С–Б_\\d#]+\\s*[+\\-]?\\s*\\d*\\]"
		},
		{
			"name": "constant.other.placeholder",
			"match": "\\[![a-zA-Z–∞-—П–Р-–ѓ—С–Б_\\d#]+\\s*[+\\-]?\\s*\\d*\\]"
		},
		{
			"match": "^(!!rule|!!section)\\s+(.+)$",
			"captures": {
				"1": {
					"name": "keyword.control"
				},
				"2": {
					"name": "string.quoted.double"
				}
			}
		},
		{
			"name": "keyword.control",
			"match": "^#\\s+(–†–Х–§–Х–†–Р–Ґ|–Ю–У–Ы–Р–Т–Ы–Х–Э–Ш–Х|–Ґ–Х–†–Ь–Ш–Э–Ђ –Ш –Ю–Я–†–Х–Ф–Х–Ы–Х–Э–Ш–ѓ|–Я–Х–†–Х–І–Х–Э–ђ –°–Ю–Ъ–†–Р–©–Х–Э–Ш–Щ –Ш –Ю–С–Ю–Ч–Э–Р–І–Х–Э–Ш–Щ|–Т–Т–Х–Ф–Х–Э–Ш–Х|–Ч–Р–Ъ–Ы–Ѓ–І–Х–Э–Ш–Х|–°–Я–Ш–°–Ю–Ъ –Ш–°–Я–Ю–Ы–ђ–Ч–Ю–Т–Р–Э–Э–Ђ–• –Ш–°–Ґ–Ю–І–Э–Ш–Ъ–Ю–Т)\\s*$"
		}
	]
}